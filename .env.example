# ── Supabase ──────────────────────────────────────────────────────────────
# URL + anon key are sent to the browser, so they MUST use the NEXT_PUBLIC_
# prefix (Next.js only exposes NEXT_PUBLIC_* to client code). The anon key is
# safe to expose; access is still gated by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key BYPASSES Row Level Security. Server-only — never prefix with
# NEXT_PUBLIC_ and never import into client code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── AI providers ──────────────────────────────────────────────────────────
# All AI calls go through lib/ai (server-only). Gemini has two backends; pick
# one with GEMINI_BACKEND ("developer" = default, or "vertex").

# Backend A — Gemini Developer API (AI Studio). Simplest: one key.
GEMINI_BACKEND=developer
GEMINI_API_KEY=your-gemini-api-key

# Backend B — Vertex AI (Google Cloud). Set GEMINI_BACKEND=vertex and provide a
# project + location. Auth is via Application Default Credentials by default
# (GOOGLE_APPLICATION_CREDENTIALS, or the service account attached to the
# runtime). For serverless, paste the service-account key JSON (stringified) into
# GOOGLE_VERTEX_CREDENTIALS instead of shipping a file.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global
# GOOGLE_VERTEX_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Per-task model routing (optional). Grading is quality-critical and can run a
# stronger model than generation. Unset → both default to gemini-2.5-flash. Use
# GEMINI_MODEL to set both at once, or override per task:
# GEMINI_GRADE_MODEL=gemini-3.1-pro-preview
# GEMINI_GENERATE_MODEL=gemini-3.5-flash

# ── Self-hosted AI backend (Contabo) ──────────────────────────────────────
# The heavy reading/writing generation endpoints live on a Python (FastAPI)
# backend the browser calls DIRECTLY with the user's Supabase access token, so
# those long requests never hit a Vercel function (escaping the 60s serverless
# cap that 504s full-test generation). NEXT_PUBLIC_ so client code can read it;
# no trailing slash. Local dev: http://localhost:8100. When unset, the studio
# falls back to the same-origin /api/reading/* routes.
NEXT_PUBLIC_AI_BACKEND_URL=https://lucid.shopsready.com/ielts

# ── App ───────────────────────────────────────────────────────────────────
# Optional. Used to build invite links when the request Origin header is absent
# (it normally isn't in form actions). Set in production, e.g. https://app.example.com
NEXT_PUBLIC_SITE_URL=
